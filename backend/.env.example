# === Core ===
PORT=4000
DATABASE_URL=
SITE_URL=https://hoantienvn.vercel.app
PUBLIC_URL=https://hoantienvn.vercel.app

# === Telegram (official) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_ENABLED=1
TELEGRAM_MODE=polling

# === Zalo Official Account (optional) ===
ZALO_OA_ACCESS_TOKEN=

# === Zalo PERSONAL via zca-js (UNOFFICIAL — ban risk, ACC PHỤ only) ===
# Tool tự động khi session die:
#   npm run zca:refresh           # QR → B64 → clipboard → (nếu có key) push Render + deploy
#   npm run zca:refresh:local     # chỉ QR + B64 + clipboard
#   npm run zca:refresh:reuse     # dùng session file sẵn, push Render
# Local nên ZCA_ENABLED=0 khi production đang chạy (tránh cướp listener)
ZCA_ENABLED=0
# ZCA_SESSION_B64=
# ZCA_SESSION_PATH=
# ZCA_ALLOW_GROUP=1
# ZCA_DEBUG=0

# === Render API (cho zca:refresh auto push) ===
# https://dashboard.render.com/u/settings#api-keys
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_ID=srv-...          # hoặc
# RENDER_SERVICE_NAME=hoantienvn-api
# RENDER_API_URL=https://hoantienvn-api.onrender.com
