# === Core ===
PORT=4000
DATABASE_URL=
SITE_URL=https://hoantienvn.vercel.app
PUBLIC_URL=https://hoantienvn.vercel.app

# === Telegram (official) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_ENABLED=1
TELEGRAM_MODE=polling

# === Zalo Official Account (optional) ===
ZALO_OA_ACCESS_TOKEN=

# === Zalo PERSONAL via zca-js (UNOFFICIAL — ban risk, ACC PHỤ only) ===
# 1) Local login: npm run zca:login  → quét QR
# 2) Bật:
ZCA_ENABLED=0
# Session file (default backend/data/zca-session.json) OR base64 for Render:
# ZCA_SESSION_B64=
# ZCA_SESSION_PATH=
# Optional group replies (default off):
# ZCA_ALLOW_GROUP=0
# ZCA_DEBUG=0
